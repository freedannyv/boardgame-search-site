generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  plays      Play[]
  ratings    GameRating[]
  collection Collection[]
  wishlist   Wishlist[]
}

model Game {
  id            String   @id @default(cuid())
  bggId         Int?     @unique
  name          String
  description   String?  @db.Text
  yearPublished Int?
  minPlayers    Int?
  maxPlayers    Int?
  playingTime   Int?
  weight        Float?
  image         String?
  thumbnail     String?
  
  // BGG ranking data (from CSV)
  rank          Int?
  bayesAverage  Float?
  average       Float?
  usersRated    Int?
  isExpansion   Boolean  @default(false)
  
  // Category-specific ranks
  abstractsRank      Int?
  cgsRank            Int?
  childrensGamesRank Int?
  familyGamesRank    Int?
  partyGamesRank     Int?
  strategyGamesRank  Int?
  thematicRank       Int?
  warGamesRank       Int?

  plays      Play[]
  ratings    GameRating[]
  collection Collection[]
  wishlist   Wishlist[]
  mechanics  GameMechanicJoin[]
  categories GameCategoryJoin[]
}

model Play {
  id          String   @id @default(cuid())
  userId      String
  gameId      String
  playDate    DateTime @default(now())
  playerCount Int?
  duration    Int?
  notes       String?  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gameId])
}

model Collection {
  id       String  @id @default(cuid())
  userId   String
  gameId   String
  owned    Boolean @default(true)
  forTrade Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model Wishlist {
  id       String @id @default(cuid())
  userId   String
  gameId   String
  priority Int    @default(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model GameRating {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  rating    Float
  review    String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model GameMechanic {
  id    String @id @default(cuid())
  bggId Int?   @unique
  name  String @unique

  games GameMechanicJoin[]
}

model GameCategory {
  id    String @id @default(cuid())
  bggId Int?   @unique
  name  String @unique

  games GameCategoryJoin[]
}

model GameMechanicJoin {
  gameId     String
  mechanicId String

  game     Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  mechanic GameMechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  @@id([gameId, mechanicId])
  @@index([gameId])
  @@index([mechanicId])
}

model GameCategoryJoin {
  gameId     String
  categoryId String

  game     Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  category GameCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([gameId, categoryId])
  @@index([gameId])
  @@index([categoryId])
}
