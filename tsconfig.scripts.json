{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "declaration": false,
    "noEmit": true
  },
  "include": [
    "server/scripts/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    "server/api/**/*"
  ]
}
