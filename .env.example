# Environment Configuration
# Copy this file to .env for local development
# For production, set these in Netlify Environment Variables

# ===========================================
# STAGING (Local Development)
# ===========================================
# Use your staging Supabase project for local development

# ===========================================
# PRODUCTION (Netlify)
# ===========================================
# Set these in Netlify dashboard > Site settings > Environment variables
# Use your production Supabase project for live site

# ===========================================
# REQUIRED VARIABLES
# ===========================================
# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# BoardGameGeek API Token (optional but recommended)
# Get from: https://boardgamegeek.com/wiki/page/BGG_XML_API2#toc3
BGG_API_TOKEN=your_bgg_api_token

# Database URL (for import scripts)
DATABASE_URL=postgresql://user:password@host:port/database

# ===========================================
# NETLIFY-SPECIFIC VARIABLES (auto-set by Netlify)
# ===========================================
# NETLIFY=true
# CONTEXT=production|deploy-preview|branch-deploy
# NODE_ENV=production
